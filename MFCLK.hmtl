<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>MCF Network Simplex Solver — RADSTRIX</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#f5f5f5;--bg2:#ebebeb;--bg3:#e0e0e0;--bg4:#d5d5d5;--card:rgba(255,255,255,.45);--card2:#fafafa;--border:#d0d0d0;--border2:#c0c0c0;--text:#1a1a1a;--text2:#4a4a4a;--text3:#888;--accent:#333;--accent2:#111;--accent-bg:#e8e8e8;--green:#2e7d32;--red:#c62828;--amber:#f57f17;--blue:#1565c0;--green-bg:rgba(46,125,50,.08);--red-bg:rgba(198,40,40,.08);--amber-bg:rgba(245,127,23,.08);--blue-bg:rgba(21,101,192,.08);--purple:#7b1fa2;--purple-bg:rgba(123,31,162,.08);--highlight:#333;--highlight-soft:rgba(0,0,0,.06);--radius:10px;--radius-sm:6px;--shadow:0 1px 3px rgba(0,0,0,.06);--shadow-lg:0 8px 30px rgba(0,0,0,.12);--canvas-bg:#fafafa;--node-fill:#fff;--node-stroke:#333;--edge-color:#bbb;--glass-bg:rgba(255,255,255,.45);--glass-border:rgba(255,255,255,.2);--glass-shadow:0 8px 32px rgba(0,0,0,.08)}
[data-theme="dark"]{--bg:#0f0f0f;--bg2:#181818;--bg3:#222;--bg4:#2a2a2a;--card:rgba(22,22,22,.65);--card2:#1a1a1a;--border:#2a2a2a;--border2:#333;--text:#e8e8e8;--text2:#aaa;--text3:#666;--accent:#e0e0e0;--accent2:#fff;--accent-bg:#1a1a1a;--green:#4caf50;--red:#ef5350;--amber:#ffb300;--blue:#42a5f5;--green-bg:rgba(76,175,80,.1);--red-bg:rgba(239,83,80,.1);--amber-bg:rgba(255,179,0,.1);--blue-bg:rgba(66,165,245,.1);--purple:#ce93d8;--purple-bg:rgba(206,147,216,.1);--highlight:#fff;--highlight-soft:rgba(255,255,255,.04);--radius:10px;--radius-sm:6px;--shadow:0 1px 3px rgba(0,0,0,.3);--shadow-lg:0 8px 30px rgba(0,0,0,.5);--canvas-bg:#141414;--node-fill:#1a1a1a;--node-stroke:#e0e0e0;--edge-color:#444;--glass-bg:rgba(22,22,22,.65);--glass-border:rgba(255,255,255,.06);--glass-shadow:0 8px 32px rgba(0,0,0,.4)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden;min-height:100vh}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:9px}
canvas#plexusBg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}
.shell{max-width:1100px;margin:0 auto;padding:0 20px;position:relative;z-index:1}
.wm{position:fixed;bottom:12px;right:18px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);opacity:.35;z-index:2;letter-spacing:2px;pointer-events:none}
.oi{position:fixed;top:14px;left:16px;z-index:100;display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace}
.oi::before{content:'';width:6px;height:6px;background:var(--green);border-radius:50%;animation:op 2s infinite}
@keyframes op{0%,100%{opacity:1}50%{opacity:.3}}
.top-bar{position:sticky;top:0;z-index:50;background:var(--glass-bg);backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid var(--glass-border);padding:10px 0;margin-bottom:30px}
.top-bar-inner{display:flex;justify-content:space-between;align-items:center;max-width:1100px;margin:0 auto;padding:0 20px}
.top-bar-logo{font-weight:700;font-size:14px;letter-spacing:-.3px}
.top-bar-right{display:flex;gap:6px;align-items:center}
.tb{background:var(--accent-bg);border:1px solid var(--border);color:var(--text);font-size:11px;padding:5px 12px;border-radius:var(--radius-sm);cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500;transition:all .2s}
.tb:hover{background:var(--bg3);border-color:var(--border2)}
.hero{text-align:center;padding:40px 0 30px}
.hero-sub{font-size:11px;text-transform:uppercase;letter-spacing:3px;color:var(--text3);margin-bottom:8px;font-weight:500}
.hero-title{font-size:clamp(22px,5vw,36px);font-weight:800;letter-spacing:-1px;line-height:1.15}
.hero-desc{font-size:13px;color:var(--text3);margin-top:8px;max-width:620px;margin-left:auto;margin-right:auto}
.section{background:var(--glass-bg);backdrop-filter:blur(16px) saturate(180%);border:1px solid var(--glass-border);border-radius:var(--radius);padding:24px;margin-bottom:20px;box-shadow:var(--glass-shadow);position:relative}
.section::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent)}
.s-title{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.s-title::before{content:'';width:3px;height:14px;background:var(--accent);border-radius:2px}
.badge{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;font-family:'JetBrains Mono',monospace;letter-spacing:.5px}
.badge-g{background:var(--green-bg);color:var(--green)}.badge-r{background:var(--red-bg);color:var(--red)}.badge-b{background:var(--blue-bg);color:var(--blue)}.badge-a{background:var(--amber-bg);color:var(--amber)}.badge-p{background:var(--purple-bg);color:var(--purple)}
input[type="text"],input[type="number"],select,textarea{font-family:'JetBrains Mono',monospace;font-size:12px;padding:7px 10px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--card2);color:var(--text);outline:none;transition:border-color .2s;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--accent)}
textarea{font-size:11px;resize:vertical;min-height:40px}
.btn{font-family:'DM Sans',sans-serif;font-weight:600;font-size:12px;padding:8px 20px;border-radius:var(--radius-sm);border:1px solid var(--border);cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:6px}
.btn-p{background:var(--accent);color:#fff;border-color:var(--accent)}.btn-p:hover{background:var(--accent2)}
.btn-s{background:var(--card2);color:var(--text)}.btn-s:hover{background:var(--bg3)}
.btn-d{background:linear-gradient(135deg,var(--green),var(--blue));color:#fff;border:none}.btn-d:hover{opacity:.9}
.btn-sm{padding:5px 12px;font-size:11px}
.btn:disabled{opacity:.4;cursor:not-allowed}
.fg{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end}
.fc{display:flex;flex-direction:column;gap:4px}
.fc label{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}
.cv-wrap{position:relative;background:var(--canvas-bg);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin:16px 0}
.cv-wrap canvas{display:block;width:100%;cursor:grab}
.cv-wrap canvas:active{cursor:grabbing}
.zoom-ctrl{position:absolute;bottom:10px;right:10px;display:flex;gap:4px}
.zoom-ctrl button{width:28px;height:28px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--card);color:var(--text);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace}
.zoom-ctrl button:hover{background:var(--bg3)}
.layout-btns{display:flex;gap:4px;margin-bottom:8px;flex-wrap:wrap}
.layout-btns button{font-family:'DM Sans',sans-serif;font-size:11px;padding:4px 12px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--card2);color:var(--text2);cursor:pointer;font-weight:500;transition:all .2s}
.layout-btns button:hover,.layout-btns button.on{background:var(--accent);color:#fff;border-color:var(--accent)}
.theme-btns{display:flex;gap:4px;margin-bottom:8px;flex-wrap:wrap;align-items:center}
.theme-btns button{font-family:'DM Sans',sans-serif;font-size:10px;padding:3px 10px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--card2);color:var(--text2);cursor:pointer;font-weight:500;transition:all .2s}
.theme-btns button:hover,.theme-btns button.on{background:var(--accent);color:#fff;border-color:var(--accent)}
.theme-label{font-size:10px;font-weight:600;color:var(--text3);margin-right:4px;text-transform:uppercase;letter-spacing:1px}
.view-btns{display:flex;gap:4px;margin-bottom:8px;flex-wrap:wrap;align-items:center}
.view-btns button{font-family:'DM Sans',sans-serif;font-size:10px;padding:3px 10px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--card2);color:var(--text2);cursor:pointer;font-weight:500;transition:all .2s}
.view-btns button:hover,.view-btns button.on{background:var(--accent);color:#fff;border-color:var(--accent)}
.iter-controls{display:flex;gap:6px;align-items:center;justify-content:center;margin:12px 0;flex-wrap:wrap}
.iter-controls button{font-family:'JetBrains Mono',monospace;font-size:11px;padding:5px 14px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--card2);color:var(--text);cursor:pointer;transition:all .2s}
.iter-controls button:hover:not(:disabled){background:var(--accent);color:#fff;border-color:var(--accent)}
.iter-controls button:disabled{opacity:.3;cursor:not-allowed}
.iter-badge{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text2);padding:4px 10px;background:var(--accent-bg);border-radius:var(--radius-sm);font-weight:600}
.play-ctrl{display:flex;gap:6px;align-items:center;justify-content:center;margin:8px 0}
.iter-detail{background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin:10px 0;font-size:12px}
.iter-changes{margin:8px 0;font-size:12px;color:var(--text2)}
.iter-changes li{margin:3px 0;padding-left:12px;position:relative;list-style:none}
.iter-changes li::before{content:'';position:absolute;left:0;top:7px;width:4px;height:4px;background:var(--accent);border-radius:50%}
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:16px}
.stat-card{background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;text-align:center}
.stat-card .sv{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700}
.stat-card .sl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.stat-card.hi{border-color:var(--green);background:var(--green-bg)}
.tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:16px;flex-wrap:wrap}
.tabs button{font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;padding:8px 16px;border:none;background:none;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s}
.tabs button:hover{color:var(--text)}
.tabs button.on{color:var(--text);border-bottom-color:var(--accent)}
.tp{display:none}.tp.on{display:block}
.rt{width:100%;border-collapse:collapse;font-size:12px;margin:10px 0}
.rt th{background:var(--accent-bg);font-weight:600;text-transform:uppercase;font-size:10px;letter-spacing:.5px;padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);color:var(--text2)}
.rt td{padding:7px 10px;border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace;font-size:11px}
.rt tr:hover td{background:var(--highlight-soft)}
.matrix-table{width:100%;border-collapse:collapse;font-size:11px;margin:10px 0}
.matrix-table th,.matrix-table td{padding:8px 10px;text-align:center;border:1px solid var(--border);font-family:'JetBrains Mono',monospace}
.matrix-table th{background:var(--accent-bg);font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--text2)}
.matrix-table td.empty-cell{background:var(--highlight-soft);color:var(--text3)}
.matrix-table td.has-value{font-weight:600;color:var(--green)}
.matrix-table .row-header{background:var(--accent-bg);font-weight:700;color:var(--text2);text-align:left;font-family:'DM Sans',sans-serif}
.ab{background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;margin:10px 0;font-size:12px;line-height:1.8;color:var(--text2)}
.ab h4{font-size:12px;font-weight:700;color:var(--text);margin:12px 0 4px;text-transform:uppercase;letter-spacing:.5px}
.toast{position:fixed;top:16px;right:16px;z-index:200;padding:10px 18px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;transform:translateX(140%);transition:transform .3s;font-family:'DM Sans',sans-serif}
.toast.show{transform:translateX(0)}
.toast-s{background:var(--green);color:#fff}.toast-e{background:var(--red);color:#fff}.toast-i{background:var(--accent);color:#fff}
.wb{background:linear-gradient(135deg,var(--green-bg),var(--blue-bg));border:2px solid var(--green);border-radius:var(--radius);padding:16px;margin:16px 0;text-align:center}
.wb h3{font-size:16px;font-weight:800;color:var(--green);margin-bottom:4px;display:flex;align-items:center;justify-content:center;gap:8px}
.wb p{font-size:12px;color:var(--text2)}
.ico{display:inline-flex;align-items:center;justify-content:center;vertical-align:middle;flex-shrink:0}
.ico svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.ico-sm svg{width:11px;height:11px}
.ico-lg svg{width:18px;height:18px}
.g-legend{display:flex;gap:14px;flex-wrap:wrap;margin:8px 0;padding:8px 12px;background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:10px;color:var(--text2);font-family:'JetBrains Mono',monospace;align-items:center}
.g-legend-item{display:flex;align-items:center;gap:5px}
.g-legend-dot{width:8px;height:8px;border-radius:50%;display:inline-block}
.cbox{background:var(--amber-bg);border:1px solid var(--amber);border-radius:var(--radius-sm);padding:12px;margin:10px 0;font-size:12px}
.fbox{background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;margin:10px 0;font-family:'JetBrains Mono',monospace;font-size:12px;line-height:2;overflow-x:auto;white-space:pre-wrap}
.node-cfg-grid{display:grid;grid-template-columns:80px 1fr 100px 100px;gap:0;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;margin:10px 0;font-size:11px}
.node-cfg-grid .ncg{padding:6px 10px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);font-family:'JetBrains Mono',monospace;display:flex;align-items:center}
.node-cfg-grid .ncg:nth-child(4n){border-right:none}
.node-cfg-grid .nch{font-weight:700;background:var(--accent-bg);font-family:'DM Sans',sans-serif;text-transform:uppercase;font-size:10px;letter-spacing:.5px;color:var(--text2)}
.node-cfg-grid input,.node-cfg-grid select{width:100%;padding:4px 6px;font-size:11px}
.cost-matrix-wrap{overflow-x:auto;margin:10px 0}
.cost-matrix-wrap table{border-collapse:collapse;font-size:11px;min-width:100%}
.cost-matrix-wrap th,.cost-matrix-wrap td{padding:6px 8px;border:1px solid var(--border);text-align:center;font-family:'JetBrains Mono',monospace}
.cost-matrix-wrap th{background:var(--accent-bg);font-weight:700;font-size:10px;color:var(--text2);min-width:70px}
.cost-matrix-wrap td input{width:60px;text-align:center;padding:4px;font-size:11px;font-family:'JetBrains Mono',monospace;border:1px solid var(--border);border-radius:3px;background:var(--card2);color:var(--text)}
.cost-matrix-wrap td input:focus{border-color:var(--accent)}
.cost-matrix-wrap td.diag{background:var(--highlight-soft);color:var(--text3)}
.cost-matrix-wrap .rh{background:var(--accent-bg);font-weight:700;color:var(--text2);text-align:left;font-family:'DM Sans',sans-serif;padding:6px 10px}
.cap-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;margin:10px 0}
.cap-card{background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px}
.cap-card .cap-label{font-size:10px;font-weight:600;color:var(--text3);margin-bottom:4px}
.cap-card input{width:100%}
/* AI INPUT */
.ai-input-area{position:relative}
.ai-input-area textarea{min-height:160px;font-family:'DM Sans',sans-serif;font-size:13px;line-height:1.7;padding:14px}
.ai-status{display:flex;align-items:center;gap:6px;margin:10px 0;font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace}
.ai-status .ai-dot{width:6px;height:6px;border-radius:50%;background:var(--green)}
.ai-result{background:var(--highlight-soft);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin:10px 0;font-size:12px;display:none}
.ai-result.show{display:block}
.ai-tag{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:4px;font-size:10px;font-weight:600;font-family:'JetBrains Mono',monospace;margin:2px}
.ai-tag-node{background:var(--blue-bg);color:var(--blue)}
.ai-tag-cost{background:var(--green-bg);color:var(--green)}
.ai-tag-cap{background:var(--amber-bg);color:var(--amber)}
.ai-tag-supply{background:var(--green-bg);color:var(--green)}
.ai-tag-demand{background:var(--red-bg);color:var(--red)}
.ai-confidence{font-family:'JetBrains Mono',monospace;font-size:10px;padding:2px 6px;border-radius:3px}
.ai-conf-high{background:var(--green-bg);color:var(--green)}
.ai-conf-med{background:var(--amber-bg);color:var(--amber)}
.ai-conf-low{background:var(--red-bg);color:var(--red)}
.ai-extract-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:10px 0}
.ai-extract-card{background:var(--card2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px}
.ai-extract-card h5{font-size:11px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:5px}
.ai-extract-list{font-size:11px;line-height:1.8}
.input-mode-tabs{display:flex;gap:0;margin-bottom:16px;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden}
.input-mode-tabs button{flex:1;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;padding:10px 16px;border:none;background:var(--card2);color:var(--text3);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px}
.input-mode-tabs button:not(:last-child){border-right:1px solid var(--border)}
.input-mode-tabs button.on{background:var(--accent);color:#fff}
.input-mode-tabs button:hover:not(.on){background:var(--bg3)}
.pulse{animation:pulse2 1.5s infinite}
@keyframes pulse2{0%,100%{opacity:1}50%{opacity:.4}}
#splashScreen{position:fixed;inset:0;z-index:9999;background:#050508;display:flex;align-items:center;justify-content:center;flex-direction:column;transition:opacity .8s,visibility .8s;overflow:hidden}
#splashScreen.hidden{opacity:0;visibility:hidden}
#splashScreen canvas{position:absolute;inset:0;z-index:0}
.sp-c{position:relative;z-index:1;text-align:center;color:#fff}
.sp-c h1{font-family:'Space Grotesk','Inter',sans-serif;font-size:clamp(36px,8vw,64px);font-weight:700;letter-spacing:14px;text-transform:uppercase;animation:sfu .8s ease both;animation-delay:.3s;opacity:0}
.sp-c p{font-size:12px;color:rgba(255,255,255,.35);margin-top:14px;animation:sfu .8s ease both;animation-delay:.6s;opacity:0;font-family:'JetBrains Mono',monospace;letter-spacing:3px;text-transform:uppercase}
.sp-bar{width:200px;height:1px;background:rgba(255,255,255,.08);border-radius:2px;margin:28px auto 0;overflow:hidden;animation:sfu .8s ease both;animation-delay:.8s;opacity:0}
.sp-bar-i{height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.8),transparent);border-radius:2px;animation:sbf 2.5s ease both;animation-delay:1s}
.sp-menu{margin-top:40px;animation:sfu .8s ease both;animation-delay:1.2s;opacity:0}
.sp-menu button{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:12px;padding:12px 40px;border-radius:var(--radius-sm);border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.02);color:rgba(255,255,255,.7);cursor:pointer;transition:all .3s;letter-spacing:6px;text-transform:uppercase}
.sp-menu button:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.2);color:#fff}
@keyframes sfu{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes sbf{from{width:0}to{width:100%}}
@media(max-width:768px){.shell{padding:0 12px}.section{padding:16px}.hero{padding:24px 0 18px}.stat-row{grid-template-columns:1fr 1fr}.node-cfg-grid{grid-template-columns:1fr 1fr 1fr 1fr;font-size:9px}.ai-extract-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div id="splashScreen"><canvas id="splashCanvas"></canvas><div class="sp-c"><h1>R A D S T R I X</h1><p>Network Simplex Solver</p><div class="sp-bar"><div class="sp-bar-i"></div></div><div class="sp-menu" id="splashMenu"><button onclick="launchApp()">M U L A I</button></div></div></div>
<canvas id="plexusBg"></canvas>
<div class="oi" id="onlineInd">1 online</div>
<div class="wm">RADSTRIX</div>
<div class="toast" id="toast"></div>
<div id="mainApp" style="display:none">
<div class="top-bar"><div class="top-bar-inner"><div class="top-bar-logo">MCF Network Simplex Solver</div><div class="top-bar-right"><button class="tb" onclick="toggleDark()" id="darkBtn">Dark</button><button class="tb" onclick="window.print()">Print</button></div></div></div>
<div class="shell">
<div class="hero"><div class="hero-sub">Penelitian Operasional 2 -- Masalah Jaringan</div><div class="hero-title">Minimum Cost Flow Solver</div><div class="hero-desc">Solver generik untuk permasalahan MCF dengan Network Simplex. Masukkan soal langsung atau input manual via tabel matriks.</div></div>

<!-- SEC 1: INPUT MODE -->
<div class="section" id="sec1">
<div class="s-title">Input Soal</div>
<div class="input-mode-tabs">
<button class="on" onclick="setInputMode('ai',this)" id="aiModeBtn"><span class="ico"><svg viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v2a3 3 0 0 1-3 3h-1v3a4 4 0 0 1-8 0v-3H7a3 3 0 0 1-3-3v-2a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/><circle cx="9" cy="10" r="1"/><circle cx="15" cy="10" r="1"/><path d="M9 14h6"/></svg></span> Parse Soal Otomatis</button>
<button onclick="setInputMode('manual',this)" id="manualModeBtn"><span class="ico"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg></span> Input Manual (Tabel)</button>
</div>

<!-- AI MODE -->
<div id="aiModePanel">
<div style="font-size:12px;color:var(--text2);margin-bottom:10px">Paste atau ketik soal MCF. Parser akan mendeteksi node, supply/demand, biaya, dan kapasitas secara otomatis.</div>
<div class="ai-input-area">
<textarea id="aiSoalInput" placeholder="Contoh: Sebuah perusahaan elektronik akan memproduksi suatu jenis televisi baru di dua pabrik yang berbeda, kemudian produk tersebut dikirimkan ke dua gudang. Pabrik A dapat mengirimkan sejumlah maksimum 40 unit televisi ke Gudang D..."></textarea>
</div>
<div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
<button class="btn btn-d" onclick="parseSoal()"><span class="ico"><svg viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v2a3 3 0 0 1-3 3h-1v3a4 4 0 0 1-8 0v-3H7a3 3 0 0 1-3-3v-2a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/><circle cx="9" cy="10" r="1"/><circle cx="15" cy="10" r="1"/><path d="M9 14h6"/></svg></span> Parse Soal</button>
<button class="btn btn-s btn-sm" onclick="loadExampleSoal()">Muat Contoh Soal</button>
<div class="ai-status" id="aiStatus" style="display:none"><div class="ai-dot pulse"></div><span id="aiStatusText">Menganalisis...</span></div>
</div>
<div class="ai-result" id="aiResult"></div>
</div>

<!-- MANUAL MODE -->
<div id="manualModePanel" style="display:none">
<div style="font-size:12px;color:var(--text2);margin-bottom:12px">Tentukan jumlah node dan konfigurasi masing-masing. Supply = positif, Demand = negatif, Transit = 0.</div>
<div class="fg" style="margin-bottom:12px">
<div class="fc" style="width:120px"><label>Jumlah Node</label><div style="display:flex;gap:4px"><button class="btn btn-sm btn-s" onclick="changeNodeCount(-1)">-</button><input type="number" id="nodeCountInp" value="5" min="2" max="12" style="width:50px;text-align:center" onchange="rebuildNodeGrid()"><button class="btn btn-sm btn-s" onclick="changeNodeCount(1)">+</button></div></div>
</div>
<div id="nodeGrid"></div>
<div style="margin-top:12px"><button class="btn btn-p btn-sm" onclick="applyNodes()">Terapkan Node</button></div>
</div>
</div>

<!-- SEC 2: COST MATRIX -->
<div class="section" id="sec2" style="display:none">
<div class="s-title">Matriks Biaya & Kapasitas</div>
<div class="tabs"><button class="on" onclick="sTab('costTab',this)">Matriks Biaya</button><button onclick="sTab('capTab',this)">Kapasitas</button></div>
<div class="tp on" id="tp-costTab"><div class="cost-matrix-wrap" id="costMatrixWrap"></div></div>
<div class="tp" id="tp-capTab"><div style="font-size:11px;color:var(--text3);margin-bottom:8px">Kosongkan = tak terbatas.</div><div class="cap-grid" id="capGrid"></div></div>
<div style="margin-top:16px;display:flex;gap:8px;flex-wrap:wrap">
<button class="btn btn-p" onclick="generateFormulation()">Generate Formulasi & Model Jaringan</button>
<button class="btn btn-d" onclick="solveNetwork()">Solve (Network Simplex)</button>
<button class="btn btn-s" onclick="resetAll()">Reset</button>
</div>
</div>

<!-- SEC 3: FORMULATION -->
<div class="section" id="sec3" style="display:none">
<div class="s-title">Formulasi Model Matematis</div>
<div class="tabs"><button class="on" onclick="sTab('fDef',this)">Definisi Elemen</button><button onclick="sTab('fMath',this)">Model Matematis</button><button onclick="sTab('fMatrix',this)">Matriks Biaya</button></div>
<div class="tp on" id="tp-fDef"><div id="fDefContent"></div></div>
<div class="tp" id="tp-fMath"><div id="fMathContent"></div></div>
<div class="tp" id="tp-fMatrix"><div id="fMatrixContent"></div></div>
</div>

<!-- SEC 4: GRAPH -->
<div class="section" id="sec4" style="display:none">
<div class="s-title">Model Jaringan</div>
<div class="layout-btns"><button class="on" onclick="setLayout('auto',this)">Auto</button><button onclick="setLayout('lr',this)">Left-Right</button><button onclick="setLayout('circle',this)">Circle</button><button onclick="setLayout('grid',this)">Grid</button><button onclick="setLayout('force',this)">Force</button></div>
<div class="theme-btns"><span class="theme-label">Theme:</span><button class="on" onclick="setGTheme('default',this)">Default</button><button onclick="setGTheme('neon',this)">Neon</button><button onclick="setGTheme('blueprint',this)">Blueprint</button><button onclick="setGTheme('sunset',this)">Sunset</button><button onclick="setGTheme('forest',this)">Forest</button><button onclick="setGTheme('cyber',this)">Cyber</button><button onclick="setGTheme('mono',this)">Mono</button><button onclick="setGTheme('ocean',this)">Ocean</button></div>
<div class="view-btns"><span class="theme-label">View:</span><button class="on" onclick="setGView('standard',this)">Standard</button><button onclick="setGView('detailed',this)">Detailed</button><button onclick="setGView('compact',this)">Compact</button></div>
<div id="gLegend" class="g-legend" style="display:none"></div>
<div class="cv-wrap"><canvas id="cv" width="800" height="580"></canvas><div class="zoom-ctrl"><button onclick="zoomIn()">+</button><button onclick="zoomOut()">-</button><button onclick="zoomReset()">R</button></div></div>
</div>

<!-- SEC 5: ITERATIONS -->
<div class="section" id="sec5" style="display:none">
<div class="s-title">Network Simplex -- Iterasi Step-by-Step</div>
<div class="iter-controls"><button onclick="iterGo(0)" id="iterFirst">|&lt;</button><button onclick="iterGo(curIter-1)" id="iterPrev">&lt;</button><span class="iter-badge" id="iterBadge">0/0</span><button onclick="iterGo(curIter+1)" id="iterNext">&gt;</button><button onclick="iterGo(iterStates.length-1)" id="iterLast">&gt;|</button></div>
<div class="play-ctrl"><button class="btn btn-sm btn-s" id="playBtn" onclick="togglePlay()">Play</button><select class="btn btn-sm btn-s" onchange="playSpd=+this.value"><option value="2000">0.5x</option><option value="1200" selected>1x</option><option value="600">2x</option></select></div>
<div class="iter-detail" id="iterDetail"></div>
<ul class="iter-changes" id="iterChanges"></ul>
<div id="solBanner"></div>
<div class="stat-row" id="solStats"></div>
<div id="solTable"></div>
</div>
</div></div>

<script>
var ICO={trophy:'<svg viewBox="0 0 24 24"><path d="M6 9H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h2M18 9h2a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-2M4 22h16M10 22V16M14 22V16"/><path d="M6 2h12v7a6 6 0 0 1-12 0V2z"/></svg>',route:'<svg viewBox="0 0 24 24"><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H18"/><circle cx="18" cy="5" r="3"/></svg>',info:'<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',target:'<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',coin:'<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="6" x2="12" y2="18"/><path d="M9 10h4.5a1.5 1.5 0 0 1 0 3H9"/></svg>',sparkle:'<svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8L12 2z"/></svg>',truck:'<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',building:'<svg viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="9" y1="6" x2="9" y2="6.01"/><line x1="15" y1="6" x2="15" y2="6.01"/><line x1="9" y1="10" x2="9" y2="10.01"/><line x1="15" y1="10" x2="15" y2="10.01"/><line x1="9" y1="14" x2="9" y2="14.01"/><line x1="15" y1="14" x2="15" y2="14.01"/><line x1="9" y1="18" x2="15" y2="18"/></svg>',home:'<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',box:'<svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',map:'<svg viewBox="0 0 24 24"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>',brain:'<svg viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 3 3v2a3 3 0 0 1-3 3h-1v3a4 4 0 0 1-8 0v-3H7a3 3 0 0 1-3-3v-2a3 3 0 0 1 3-3h1V6a4 4 0 0 1 4-4z"/><circle cx="9" cy="10" r="1"/><circle cx="15" cy="10" r="1"/><path d="M9 14h6"/></svg>'};
function ico(n,s){return'<span class="ico'+(s==='sm'?' ico-sm':s==='lg'?' ico-lg':'')+'">'+ICO[n]+'</span>'}
var isDark=false,sc=1,di=-1,dOff={x:0,y:0},cLo='auto';
var curIter=0,iterStates=[],playInt=null,playSpd=1200;
var gTheme='default',gView='standard';
var mouseXBg=0,mouseYBg=0;
var nodes=[],arcs=[],pos=[],NODE_R=28,cvEl,ctx,sol=null,pCnt=0;
var GRAPH_THEMES={default:{supply:null,transit:null,demand:null,nodeFill:null,edgeActive:null,edgeInactive:null,bg:null,glow:'#1565c0',labelBg:null,nodeGlow:true},neon:{supply:'#00e676',transit:'#ffd600',demand:'#ff1744',nodeFill:'#0a0a12',edgeActive:'#00e5ff',edgeInactive:'#1a1a2e',bg:'#08080f',glow:'#00e5ff',labelBg:'#0a0a12',nodeGlow:true},blueprint:{supply:'#90caf9',transit:'#fff176',demand:'#ef9a9a',nodeFill:'#0d1b2a',edgeActive:'#64b5f6',edgeInactive:'#1b3a5c',bg:'#0d1b2a',glow:'#42a5f5',labelBg:'#0d1b2a',nodeGlow:true},sunset:{supply:'#ff8a65',transit:'#ffd54f',demand:'#e57373',nodeFill:'#1a0a00',edgeActive:'#ffab40',edgeInactive:'#3e2723',bg:'#1a0f05',glow:'#ff6d00',labelBg:'#1a0f05',nodeGlow:true},forest:{supply:'#66bb6a',transit:'#aed581',demand:'#a1887f',nodeFill:'#0a1a0a',edgeActive:'#81c784',edgeInactive:'#1b3a1b',bg:'#0a150a',glow:'#4caf50',labelBg:'#0a150a',nodeGlow:true},cyber:{supply:'#e040fb',transit:'#40c4ff',demand:'#ff4081',nodeFill:'#0a0015',edgeActive:'#e040fb',edgeInactive:'#1a0030',bg:'#06000f',glow:'#e040fb',labelBg:'#0a0015',nodeGlow:true},mono:{supply:'#888',transit:'#aaa',demand:'#666',nodeFill:null,edgeActive:null,edgeInactive:null,bg:null,glow:'#666',labelBg:null,nodeGlow:false},ocean:{supply:'#26a69a',transit:'#4dd0e1',demand:'#0277bd',nodeFill:'#001a1a',edgeActive:'#00bcd4',edgeInactive:'#003333',bg:'#001215',glow:'#00bcd4',labelBg:'#001215',nodeGlow:true}};
var PP={tujuan:['Tujuan permasalahan ini adalah meminimumkan total biaya pengiriman produk dari sumber ke tujuan.','Permasalahan ini bertujuan mencari total biaya pengiriman paling rendah dalam jaringan distribusi.','Yang ingin dicapai adalah minimisasi biaya total pengiriman seluruh produk dari supply ke demand.','Fokus utama adalah meminimalkan total biaya distribusi produk melalui jaringan.'],varKep:['Variabel keputusan x_ij merepresentasikan jumlah produk yang dialirkan dari node i ke node j.','Setiap x_ij menunjukkan banyaknya unit yang mengalir pada jalur i ke j.','Jumlah produk yang dikirim melalui jalur i ke j dinyatakan oleh x_ij.','x_ij didefinisikan sebagai banyaknya unit yang mengalir dari node i ke node j.'],solOpt:['Solusi optimal ditemukan dengan total biaya minimum','Hasil optimasi menunjukkan biaya paling rendah adalah','Total biaya minimum dari network simplex adalah','Biaya optimal yang ditemukan sebesar']};
function pickP(k){var p=PP[k];if(!p||!p.length)return'';return p[(pCnt+Math.floor(Math.random()*p.length))%p.length]}

/* ===== SPLASH ===== */
(function(){var c=document.getElementById('splashCanvas'),x=c.getContext('2d'),pts=[],mx=0,my=0;function rz(){c.width=innerWidth;c.height=innerHeight}rz();addEventListener('resize',rz);c.parentElement.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY});for(var i=0;i<100;i++)pts.push({x:Math.random()*2000-500,y:Math.random()*1400-200,z:Math.random()*800,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,vz:(Math.random()-.5)*.6,r:Math.random()*1.8+.3,b:Math.random()*.5+.5,hue:200+Math.random()*60});function proj(p){var f=900,s=f/(f+p.z);return{x:c.width/2+(p.x-c.width/2)*s,y:c.height/2+(p.y-c.height/2)*s,s:s}}function draw(){x.fillStyle='rgba(5,5,8,.15)';x.fillRect(0,0,c.width,c.height);var sorted=pts.slice().sort(function(a,b){return b.z-a.z});for(var i=0;i<sorted.length;i++){var a=sorted[i];a.x+=a.vx;a.y+=a.vy;a.z+=a.vz;if(a.x<-500||a.x>c.width+500)a.vx*=-1;if(a.y<-200||a.y>c.height+200)a.vy*=-1;if(a.z<0||a.z>800)a.vz*=-1;var pa=proj(a);var mIn=Math.max(0,1-Math.sqrt((pa.x-mx)*(pa.x-mx)+(pa.y-my)*(pa.y-my))/200);for(var j=i+1;j<sorted.length;j++){var b2=sorted[j];var pb=proj(b2);var dx=pa.x-pb.x,dy=pa.y-pb.y,d=Math.sqrt(dx*dx+dy*dy);if(d<160){var al=(1-d/160)*Math.min(pa.s,pb.s)*(.3+mIn*2.5);if(al>1)al=1;if(mIn>.3){var grad=x.createLinearGradient(pa.x,pa.y,pb.x,pb.y);grad.addColorStop(0,'hsla('+a.hue+',80%,70%,'+al+')');grad.addColorStop(1,'hsla('+b2.hue+',80%,70%,'+al+')');x.strokeStyle=grad}else x.strokeStyle='rgba(140,170,220,'+al*.6+')';x.beginPath();x.moveTo(pa.x,pa.y);x.lineTo(pb.x,pb.y);x.lineWidth=Math.min((.3+mIn*2)*Math.min(pa.s,pb.s),2.5);x.stroke();x.shadowBlur=0}}var dotSz=a.r*pa.s,dotA=Math.min(1,a.b*pa.s*(.5+mIn*1.5));if(mIn>.2){var grd=x.createRadialGradient(pa.x,pa.y,0,pa.x,pa.y,dotSz*5);grd.addColorStop(0,'hsla('+a.hue+',80%,75%,'+dotA*.5+')');grd.addColorStop(1,'transparent');x.fillStyle=grd;x.beginPath();x.arc(pa.x,pa.y,dotSz*5,0,Math.PI*2);x.fill()}x.fillStyle='rgba(220,235,255,'+dotA*.8+')';x.beginPath();x.arc(pa.x,pa.y,dotSz*.4,0,Math.PI*2);x.fill()}requestAnimationFrame(draw)}draw();setTimeout(function(){document.getElementById('splashMenu').style.pointerEvents='auto';document.getElementById('splashMenu').style.opacity='1'},3200);window.launchApp=function(){var sp=document.getElementById('splashScreen');sp.classList.add('hidden');setTimeout(function(){sp.style.display='none';startApp()},900)}})();
function initPlexus(){var c=document.getElementById('plexusBg'),x=c.getContext('2d'),pts=[];function rz(){c.width=innerWidth;c.height=innerHeight}rz();addEventListener('resize',rz);document.addEventListener('mousemove',function(e){mouseXBg=e.clientX;mouseYBg=e.clientY});for(var i=0;i<55;i++)pts.push({x:Math.random()*c.width,y:Math.random()*c.height,z:Math.random()*500,vx:(Math.random()-.5)*.2,vy:(Math.random()-.5)*.2,vz:(Math.random()-.5)*.3,r:Math.random()*1.2+.4,b:Math.random()*.5+.5,hue:190+Math.random()*40});function proj(p){var f=700,s=f/(f+p.z);return{x:c.width/2+(p.x-c.width/2)*s,y:c.height/2+(p.y-c.height/2)*s,s:s}}function draw(){var isDk=document.documentElement.getAttribute('data-theme')==='dark';x.clearRect(0,0,c.width,c.height);for(var i=0;i<pts.length;i++){var a=pts[i];a.x+=a.vx;a.y+=a.vy;a.z+=a.vz;if(a.x<0||a.x>c.width)a.vx*=-1;if(a.y<0||a.y>c.height)a.vy*=-1;if(a.z<0||a.z>500)a.vz*=-1;var pa=proj(a);var mI=Math.max(0,1-Math.sqrt((pa.x-mouseXBg)*(pa.x-mouseXBg)+(pa.y-mouseYBg)*(pa.y-mouseYBg))/180);for(var j=i+1;j<pts.length;j++){var b=pts[j];var pb=proj(b);var d=Math.sqrt((pa.x-pb.x)*(pa.x-pb.x)+(pa.y-pb.y)*(pa.y-pb.y));if(d<150){var al=Math.min(1,(1-d/150)*Math.min(pa.s,pb.s)*(.15+Math.max(mI,Math.max(0,1-Math.sqrt((pb.x-mouseXBg)*(pb.x-mouseXBg)+(pb.y-mouseYBg)*(pb.y-mouseYBg))/180))*2));x.strokeStyle=isDk?'rgba(255,255,255,'+al*.12+')':'rgba(0,0,0,'+al*.1+')';x.beginPath();x.moveTo(pa.x,pa.y);x.lineTo(pb.x,pb.y);x.lineWidth=.5;x.stroke()}}var cA=isDk?Math.min(1,a.b*pa.s*.4):Math.min(1,a.b*pa.s*.3);x.fillStyle=isDk?'rgba(200,220,255,'+cA+')':'rgba(40,60,100,'+cA+')';x.beginPath();x.arc(pa.x,pa.y,a.r*pa.s*.5,0,Math.PI*2);x.fill()}requestAnimationFrame(draw)}draw()}
function startApp(){initPlexus();if(localStorage.getItem('mcfdk')==='1'){isDark=true;document.documentElement.setAttribute('data-theme','dark');document.getElementById('darkBtn').textContent='Light'}document.getElementById('mainApp').style.display='block';initCanvas();rebuildNodeGrid();var b=3+Math.floor(Math.random()*8);setInterval(function(){document.getElementById('onlineInd').textContent=(b+Math.floor(Math.random()*5)-2)+' online'},8000)}
function toggleDark(){isDark=!isDark;document.documentElement.setAttribute('data-theme',isDark?'dark':'light');document.getElementById('darkBtn').textContent=isDark?'Light':'Dark';localStorage.setItem('mcfdk',isDark?'1':'0');if(pos.length)drawGraph()}
function toast(m,t){var el=document.getElementById('toast');el.textContent=m;el.className='toast show '+(t==='success'?'toast-s':t==='error'?'toast-e':'toast-i');setTimeout(function(){el.classList.remove('show')},2500)}
function sTab(n,b){b.parentElement.querySelectorAll('button').forEach(function(x){x.classList.remove('on')});b.classList.add('on');b.parentElement.parentElement.querySelectorAll('.tp').forEach(function(x){x.classList.remove('on')});document.getElementById('tp-'+n).classList.add('on')}
function setGTheme(t,btn){gTheme=t;document.querySelectorAll('.theme-btns button').forEach(function(b){b.classList.remove('on')});if(btn)btn.classList.add('on');if(pos.length)drawGraph()}
function setGView(v,btn){gView=v;document.querySelectorAll('.view-btns button').forEach(function(b){b.classList.remove('on')});if(btn)btn.classList.add('on');if(pos.length)drawGraph()}

/* ===== INPUT MODE ===== */
function setInputMode(mode,btn){
document.querySelectorAll('.input-mode-tabs button').forEach(function(b){b.classList.remove('on')});
btn.classList.add('on');
document.getElementById('aiModePanel').style.display=mode==='ai'?'block':'none';
document.getElementById('manualModePanel').style.display=mode==='manual'?'block':'none';
}

/* ===== AI SOAL PARSER ===== */
function loadExampleSoal(){
document.getElementById('aiSoalInput').value='Sebuah perusahaan elektronik akan memproduksi suatu jenis televisi baru di dua pabrik yang berbeda, kemudian produk tersebut dikirimkan ke dua gudang. Pabrik A dapat mengirimkan sejumlah maksimum 40 unit televisi ke Gudang D. Pabrik B dapat mengirimkan sejumlah maksimum 40 unit televisi ke Gudang E. Pabrik B dapat mengirimkan televisi ke Pabrik A tanpa batasan kapasitas. Selain itu, setiap pabrik dapat mengirimkan televisi ke sebuah distribution center C, dan distribution center C dapat mengirimkan televisi ke setiap gudang, tanpa batasan kapasitas.\n\nPabrik A memproduksi sejumlah 50 unit produk, sedangkan Pabrik B memproduksi sejumlah 80 unit produk. Alokasi untuk Gudang D adalah sejumlah 70 unit produk, sedangkan alokasi untuk Gudang E adalah sejumlah 60 unit televisi.\n\nBiaya pengiriman:\nDari Pabrik A ke Distribution Center C = 4\nDari Pabrik A ke Gudang D = 6\nDari Pabrik B ke Pabrik A = 1\nDari Pabrik B ke Distribution Center C = 2\nDari Pabrik B ke Gudang E = 5\nDari Distribution Center C ke Gudang D = 3\nDari Distribution Center C ke Gudang E = 5';
toast('Contoh soal dimuat','success');
}

function parseSoal(){
var text=document.getElementById('aiSoalInput').value.trim();
if(!text){toast('Masukkan soal terlebih dahulu','error');return}
var st=document.getElementById('aiStatus');st.style.display='flex';
document.getElementById('aiStatusText').textContent='Menganalisis teks...';
setTimeout(function(){
document.getElementById('aiStatusText').textContent='Mendeteksi node...';
setTimeout(function(){
document.getElementById('aiStatusText').textContent='Mengekstrak biaya & kapasitas...';
setTimeout(function(){
var result=doParseNLP(text);
st.style.display='none';
showParseResult(result);
},400);
},400);
},300);
}

function doParseNLP(text){
var t=text.toLowerCase();
var result={nodes:[],costs:[],caps:[],confidence:0,details:[]};

// ===== NODE DETECTION =====
var nodePatterns=[
{rx:/pabrik\s+([A-Za-z])/gi,type:'factory'},
{rx:/gudang\s+([A-Za-z])/gi,type:'warehouse'},
{rx:/distribution\s*center\s+([A-Za-z])/gi,type:'dc'},
{rx:/pusat\s*distribusi\s+([A-Za-z])/gi,type:'dc'},
{rx:/kantor\s+([A-Za-z])/gi,type:'office'},
{rx:/kota\s+([A-Za-z])/gi,type:'city'},
{rx:/lokasi\s+([A-Za-z])/gi,type:'location'},
{rx:/node\s+([A-Za-z])/gi,type:'node'},
{rx:/titik\s+([A-Za-z])/gi,type:'node'},
{rx:/sumber\s+([A-Za-z])/gi,type:'source'},
{rx:/tujuan\s+([A-Za-z])/gi,type:'sink'}
];
var foundNodes={};
var nodeNames={};
nodePatterns.forEach(function(pat){
var m;while((m=pat.rx.exec(text))!==null){
var id=m[1].toUpperCase();
if(!foundNodes[id]){
foundNodes[id]=pat.type;
var fullMatch=m[0];
nodeNames[id]=fullMatch.charAt(0).toUpperCase()+fullMatch.slice(1).replace(/\s+/g,' ').trim();
}
}
});

// ===== SUPPLY/DEMAND DETECTION =====
var supplyDemand={};
// Supply patterns
var supPats=[
/(?:pabrik|sumber|node|titik)\s+([A-Za-z])\s+(?:memproduksi|menyediakan|menghasilkan|memiliki\s+(?:pasokan|supply))\s+(?:sejumlah\s+)?(\d+)/gi,
/(?:pabrik|sumber)\s+([A-Za-z]).*?(?:kapasitas|produksi|supply).*?(\d+)/gi,
/(?:supply|pasokan)\s+(?:pada|di|dari)\s+(?:pabrik|node|sumber)\s+([A-Za-z]).*?(\d+)/gi
];
supPats.forEach(function(rx){
var m;while((m=rx.exec(text))!==null){
supplyDemand[m[1].toUpperCase()]={val:parseInt(m[2]),type:'supply'};
}
});
// Demand patterns
var demPats=[
/(?:alokasi|kebutuhan|demand)\s+(?:untuk|pada|di)\s+(?:gudang|kantor|tujuan)\s+([A-Za-z])\s+(?:adalah\s+)?(?:sejumlah\s+)?(\d+)/gi,
/(?:gudang|kantor|tujuan)\s+([A-Za-z]).*?(?:membutuhkan|memerlukan|menerima|alokasi).*?(\d+)/gi,
/(?:gudang|tujuan)\s+([A-Za-z]).*?(?:sejumlah)\s+(\d+)/gi
];
demPats.forEach(function(rx){
var m;while((m=rx.exec(text))!==null){
supplyDemand[m[1].toUpperCase()]={val:parseInt(m[2]),type:'demand'};
}
});

// Build nodes
for(var id in foundNodes){
var sd=supplyDemand[id];
var bi=0,type='transit';
if(sd){bi=sd.type==='supply'?sd.val:-sd.val;type=sd.type}
else if(foundNodes[id]==='factory'||foundNodes[id]==='source'){type='supply'}
else if(foundNodes[id]==='warehouse'||foundNodes[id]==='sink'||foundNodes[id]==='office'){type='demand'}
else{type='transit'}
result.nodes.push({id:id,name:nodeNames[id]||id,bi:bi,type:type});
}

// ===== COST DETECTION =====
var costPats=[
/(?:dari|from)\s+(?:pabrik|gudang|distribution\s*center|pusat\s*distribusi|node|titik|sumber|tujuan)\s+([A-Za-z])\s+(?:ke|to|menuju)\s+(?:pabrik|gudang|distribution\s*center|pusat\s*distribusi|node|titik|sumber|tujuan)\s+([A-Za-z])\s*(?:=|:|\s+)\s*(\d+)/gi,
/([A-Za-z])\s*(?:ke|->|-->)\s*([A-Za-z])\s*(?:=|:)\s*(\d+)/gi,
/biaya.*?([A-Za-z])\s+(?:ke|->)\s+([A-Za-z]).*?(\d+)/gi
];
var foundCosts={};
costPats.forEach(function(rx){
var m;while((m=rx.exec(text))!==null){
var f=m[1].toUpperCase(),t2=m[2].toUpperCase(),c=parseInt(m[3]);
var ck=f+'_'+t2;
if(f!==t2&&!foundCosts[ck]){foundCosts[ck]=c;result.costs.push({from:f,to:t2,cost:c})}
}
});

// Also try table-like patterns: A - 4 6 -
var tableMatch=text.match(/(?:pabrik|node)\s+([a-z])\s+[-]\s+(\d+)\s+(\d+)\s+[-]/gi);

// ===== CAPACITY DETECTION =====
var capPats=[
/(?:pabrik|node|sumber|gudang|titik)\s+([A-Za-z])\s+(?:dapat\s+)?(?:mengirimkan|mengirim)\s+(?:sejumlah\s+)?(?:maksimum|maksimal|max|paling\s+banyak)\s+(\d+)\s+(?:unit|produk|televisi|barang)?\s*(?:ke|menuju)\s+(?:pabrik|gudang|distribution\s*center|node|titik)\s+([A-Za-z])/gi,
/(?:kapasitas|capacity|max|maksimum)\s+(?:dari\s+)?([A-Za-z])\s*(?:ke|->)\s*([A-Za-z])\s*(?:=|:|\s+)\s*(\d+)/gi,
/u\s*([A-Za-z])([A-Za-z])\s*(?:=|<=)\s*(\d+)/gi
];
var foundCaps={};
capPats.forEach(function(rx){
var m;while((m=rx.exec(text))!==null){
var f,t2,c;
if(m.length===4&&/[A-Za-z]/.test(m[1])&&/[A-Za-z]/.test(m[3])){
f=m[1].toUpperCase();t2=m[3].toUpperCase();c=parseInt(m[2]);
}else if(m.length===4){
f=m[1].toUpperCase();t2=m[2].toUpperCase();c=parseInt(m[3]);
}
if(f&&t2&&c&&!foundCaps[f+'_'+t2]){foundCaps[f+'_'+t2]=c;result.caps.push({from:f,to:t2,cap:c})}
}
});

// ===== CONFIDENCE =====
var conf=0;
if(result.nodes.length>=2)conf+=30;
if(result.nodes.length>=4)conf+=10;
if(result.costs.length>=2)conf+=25;
if(result.costs.length>=4)conf+=10;
var hasSupply=result.nodes.some(function(n){return n.bi>0});
var hasDemand=result.nodes.some(function(n){return n.bi<0});
if(hasSupply)conf+=10;
if(hasDemand)conf+=10;
if(result.caps.length>0)conf+=5;
result.confidence=Math.min(100,conf);

// Details
result.details.push('Terdeteksi '+result.nodes.length+' node');
result.details.push('Terdeteksi '+result.costs.length+' jalur biaya');
result.details.push('Terdeteksi '+result.caps.length+' batasan kapasitas');
if(hasSupply)result.details.push('Supply terdeteksi');
if(hasDemand)result.details.push('Demand terdeteksi');

return result;
}

function showParseResult(r){
var el=document.getElementById('aiResult');
var confClass=r.confidence>=70?'ai-conf-high':r.confidence>=40?'ai-conf-med':'ai-conf-low';
var h='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px"><div style="font-weight:700;font-size:13px">'+ico('brain')+' Hasil Analisis</div><span class="ai-confidence '+confClass+'">Confidence: '+r.confidence+'%</span></div>';

if(r.confidence<30){
h+='<div class="cbox">Confidence rendah. Pastikan soal memuat informasi node, supply/demand, dan biaya dengan jelas. Gunakan input manual jika parser tidak akurat.</div>';
}

h+='<div class="ai-extract-grid">';
// Nodes
h+='<div class="ai-extract-card"><h5>'+ico('box','sm')+' Node Terdeteksi ('+r.nodes.length+')</h5><div class="ai-extract-list">';
r.nodes.forEach(function(n){
var tagClass=n.bi>0?'ai-tag-supply':n.bi<0?'ai-tag-demand':'ai-tag-node';
h+='<span class="ai-tag '+tagClass+'">'+n.id+': '+n.name+' (b='+n.bi+')</span> ';
});
h+='</div></div>';
// Costs
h+='<div class="ai-extract-card"><h5>'+ico('coin','sm')+' Biaya Terdeteksi ('+r.costs.length+')</h5><div class="ai-extract-list">';
r.costs.forEach(function(c){h+='<span class="ai-tag ai-tag-cost">'+c.from+'->'+c.to+' = '+c.cost+'</span> '});
h+='</div></div>';
// Caps
h+='<div class="ai-extract-card"><h5>'+ico('route','sm')+' Kapasitas Terdeteksi ('+r.caps.length+')</h5><div class="ai-extract-list">';
if(r.caps.length)r.caps.forEach(function(c){h+='<span class="ai-tag ai-tag-cap">'+c.from+'->'+c.to+' max '+c.cap+'</span> '});
else h+='<span style="color:var(--text3);font-size:11px">Tidak ada batasan terdeteksi</span>';
h+='</div></div>';
// Details
h+='<div class="ai-extract-card"><h5>'+ico('info','sm')+' Detail Parsing</h5><div class="ai-extract-list">';
r.details.forEach(function(d){h+='<div style="font-size:11px;color:var(--text2)">'+d+'</div>'});
h+='</div></div>';
h+='</div>';

h+='<div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap">';
h+='<button class="btn btn-p" onclick="applyParseResult()">Terapkan Hasil Parsing</button>';
h+='<button class="btn btn-s btn-sm" onclick="setInputMode(\'manual\',document.getElementById(\'manualModeBtn\'))">Edit Manual</button>';
h+='</div>';

el.innerHTML=h;el.classList.add('show');
window._lastParseResult=r;
toast('Parsing selesai! Confidence: '+r.confidence+'%',r.confidence>=50?'success':'info');
}

function applyParseResult(){
var r=window._lastParseResult;if(!r||!r.nodes.length){toast('Tidak ada hasil parsing','error');return}
nodes=r.nodes.slice();
// Ensure b values balance
var total=0;nodes.forEach(function(n){total+=n.bi});
if(total!==0){
toast('Total b(i) = '+total+', harus 0. Periksa supply/demand.','error');
}
buildCostMatrix();
// Fill costs
setTimeout(function(){
r.costs.forEach(function(c){
var el=document.getElementById('cm_'+c.from+'_'+c.to);
if(el)el.value=c.cost;
});
r.caps.forEach(function(c){
var el=document.getElementById('cap_'+c.from+'_'+c.to);
if(el)el.value=c.cap;
});
},100);
document.getElementById('sec2').style.display='block';
toast('Data berhasil diterapkan! Periksa matriks biaya.','success');
document.getElementById('sec2').scrollIntoView({behavior:'smooth'});
}

/* ===== MANUAL NODE GRID ===== */
function changeNodeCount(d){var inp=document.getElementById('nodeCountInp');inp.value=Math.max(2,Math.min(12,parseInt(inp.value)+d));rebuildNodeGrid()}
function rebuildNodeGrid(){
var n=parseInt(document.getElementById('nodeCountInp').value)||5;
var defs='ABCDEFGHIJKL'.split('');
var h='<div class="node-cfg-grid"><div class="ncg nch">ID</div><div class="ncg nch">Nama</div><div class="ncg nch">b(i)</div><div class="ncg nch">Tipe</div>';
for(var i=0;i<n;i++){h+='<div class="ncg"><input type="text" id="nid_'+i+'" value="'+defs[i]+'" style="width:40px;text-align:center" onchange="updateNT('+i+')"></div><div class="ncg"><input type="text" id="nnm_'+i+'" value="Node '+defs[i]+'"></div><div class="ncg"><input type="number" id="nbi_'+i+'" value="0" onchange="updateNT('+i+')"></div><div class="ncg"><span id="ntype_'+i+'" class="badge badge-a">TRANSIT</span></div>'}
h+='</div>';document.getElementById('nodeGrid').innerHTML=h;
}
function updateNT(i){var bi=parseInt(document.getElementById('nbi_'+i).value)||0;var el=document.getElementById('ntype_'+i);if(bi>0){el.className='badge badge-g';el.textContent='SUPPLY'}else if(bi<0){el.className='badge badge-r';el.textContent='DEMAND'}else{el.className='badge badge-a';el.textContent='TRANSIT'}}
function applyNodes(){
var n=parseInt(document.getElementById('nodeCountInp').value)||5;nodes=[];var ids={};
for(var i=0;i<n;i++){var id=(document.getElementById('nid_'+i).value||'').trim().toUpperCase();var nm=(document.getElementById('nnm_'+i).value||'').trim();var bi=parseInt(document.getElementById('nbi_'+i).value)||0;if(!id){toast('ID node kosong','error');return}if(ids[id]){toast('ID "'+id+'" duplikat','error');return}ids[id]=true;nodes.push({id:id,name:nm||id,bi:bi,type:bi>0?'supply':bi<0?'demand':'transit'})}
var tot=0;nodes.forEach(function(n){tot+=n.bi});if(tot!==0){toast('Total b(i) = '+tot+', harus 0','error');return}
buildCostMatrix();document.getElementById('sec2').style.display='block';toast('Node diterapkan','success');document.getElementById('sec2').scrollIntoView({behavior:'smooth'});
}

/* ===== COST MATRIX ===== */
function buildCostMatrix(){
var h='<table><thead><tr><th>Dari \\ Ke</th>';nodes.forEach(function(n){h+='<th>'+n.id+'</th>'});h+='</tr></thead><tbody>';
nodes.forEach(function(fr,fi){h+='<tr><td class="rh">'+fr.id+' - '+fr.name.substring(0,12)+'</td>';nodes.forEach(function(to,ti){if(fi===ti)h+='<td class="diag">-</td>';else h+='<td><input type="number" id="cm_'+fr.id+'_'+to.id+'" placeholder="-" min="0"></td>'});h+='</tr>'});
h+='</tbody></table>';document.getElementById('costMatrixWrap').innerHTML=h;
var ch='';nodes.forEach(function(fr){nodes.forEach(function(to){if(fr.id!==to.id)ch+='<div class="cap-card"><div class="cap-label">'+ico('route','sm')+' '+fr.id+' -> '+to.id+'</div><input type="number" id="cap_'+fr.id+'_'+to.id+'" placeholder="Tak terbatas" min="0"></div>'})});
document.getElementById('capGrid').innerHTML=ch;
}
function readArcs(){arcs=[];nodes.forEach(function(fr){nodes.forEach(function(to){if(fr.id===to.id)return;var el=document.getElementById('cm_'+fr.id+'_'+to.id);if(!el||el.value.trim()===''||isNaN(+el.value))return;var capEl=document.getElementById('cap_'+fr.id+'_'+to.id);var cap=Infinity;if(capEl&&capEl.value.trim()!=='')cap=+capEl.value;arcs.push({id:fr.id+to.id,from:fr.id,to:to.id,cost:+el.value,cap:cap})})});return arcs.length>0}

/* ===== GENERATE ===== */
function generateFormulation(){if(!readArcs()){toast('Isi biaya dulu','error');return}pCnt++;buildFDef();buildFMath();buildFMat();pos=[];for(var i=0;i<nodes.length;i++)pos.push({x:0,y:0});applyLayout();drawGraph();updateLegend();document.getElementById('sec3').style.display='block';document.getElementById('sec4').style.display='block';toast('Formulasi berhasil!','success');document.getElementById('sec3').scrollIntoView({behavior:'smooth'})}
function nodeName(id){var n=nodes.find(function(x){return x.id===id});return n?n.name:id}
function buildFDef(){var h='<div class="ab"><h4>'+ico('target')+' Tujuan</h4><p>'+pickP('tujuan')+'</p><h4>'+ico('truck')+' Variabel Keputusan</h4><p>'+pickP('varKep')+'</p><table class="rt"><tr><th>Variabel</th><th>Jalur</th><th>Keterangan</th></tr>';arcs.forEach(function(a){h+='<tr><td>x<sub>'+a.id+'</sub></td><td>'+a.from+' -> '+a.to+'</td><td>'+nodeName(a.from)+' -> '+nodeName(a.to)+'</td></tr>'});h+='</table><h4>'+ico('building')+' Supply/Demand</h4><table class="rt"><tr><th>Node</th><th>Nama</th><th>b(i)</th><th>Tipe</th></tr>';nodes.forEach(function(n){var col=n.bi>0?'var(--green)':n.bi<0?'var(--red)':'var(--amber)';var bg=n.type==='supply'?'badge-g':n.type==='demand'?'badge-r':'badge-a';h+='<tr><td>'+n.id+'</td><td>'+n.name+'</td><td style="color:'+col+';font-weight:700">'+(n.bi>0?'+':'')+n.bi+'</td><td><span class="badge '+bg+'">'+n.type.toUpperCase()+'</span></td></tr>'});h+='</table></div>';document.getElementById('fDefContent').innerHTML=h}
function buildFMath(){var h='<div class="fbox"><strong>Fungsi Tujuan:</strong>\nMin Z = '+arcs.map(function(a){return a.cost+' x<sub>'+a.id+'</sub>'}).join(' + ')+'\n\n<strong>Pembatas:</strong>\n';nodes.forEach(function(nd){var terms=[];arcs.forEach(function(a){if(a.from===nd.id)terms.push('+ x<sub>'+a.id+'</sub>');if(a.to===nd.id)terms.push('- x<sub>'+a.id+'</sub>')});if(terms.length)h+='Node '+nd.id+': '+terms.join(' ')+' = '+nd.bi+'\n'});h+='\n<strong>Kapasitas:</strong>\n';arcs.forEach(function(a){if(a.cap!==Infinity)h+='x<sub>'+a.id+'</sub> <= '+a.cap+'\n'});h+='\nx<sub>ij</sub> >= 0\n</div>';document.getElementById('fMathContent').innerHTML=h}
function buildFMat(){var h='<div class="ab"><h4>'+ico('map')+' Matriks Biaya</h4><div style="overflow-x:auto"><table class="matrix-table"><thead><tr><th>Dari\\Ke</th>';nodes.forEach(function(n){h+='<th>'+n.id+'</th>'});h+='</tr></thead><tbody>';var aMap={};arcs.forEach(function(a){aMap[a.from+'_'+a.to]=a.cost});nodes.forEach(function(fr){h+='<tr><td class="row-header">'+fr.id+'</td>';nodes.forEach(function(to){var k=fr.id+'_'+to.id;if(fr.id===to.id)h+='<td class="empty-cell">-</td>';else if(aMap[k]!==undefined)h+='<td class="has-value">'+aMap[k]+'</td>';else h+='<td class="empty-cell">-</td>'});h+='</tr>'});h+='</tbody></table></div></div>';document.getElementById('fMatrixContent').innerHTML=h}

/* ===== SOLVER ===== */
function solveNetwork(){if(!readArcs()){toast('Isi biaya dulu','error');return}if(document.getElementById('sec3').style.display==='none')generateFormulation();pCnt++;iterStates=[];var res=networkSimplex(nodes,arcs);if(!res){toast('Tidak dapat menemukan solusi layak','error');return}sol=res;curIter=0;document.getElementById('sec5').style.display='block';iterGo(0);buildSolRes();toast('Solusi optimal ditemukan!','success');document.getElementById('sec5').scrollIntoView({behavior:'smooth'})}
function networkSimplex(nds,acs){var n=nds.length;var nIdx={};nds.forEach(function(nd,i){nIdx[nd.id]=i});var flows={};acs.forEach(function(a){flows[a.id]=0});var tree=findTree(nds,acs);if(!tree)return null;var basisArcs=tree,nonBasis=[];acs.forEach(function(a){if(basisArcs.indexOf(a.id)<0)nonBasis.push(a.id)});var bf=solveFlows(nds,acs,basisArcs);if(bf)for(var k in bf)flows[k]=bf[k];function Z(){var z=0;acs.forEach(function(a){z+=flows[a.id]*a.cost});return z}function arcById(id){return acs.find(function(a){return a.id===id})}
var fS=[];for(var k2 in flows)if(flows[k2]>0)fS.push('x_'+k2+'='+flows[k2]);iterStates.push({title:'Iterasi 1 - Initial Spanning Tree',desc:'Basis: '+basisArcs.join(', '),changes:['Variabel Basis: '+basisArcs.join(', '),'Variabel Non-Basis: '+nonBasis.join(', '),'Aliran: '+fS.join(', '),'Z = '+Z()],flows:Object.assign({},flows),basis:basisArcs.slice()});
var maxI=50,it=0;while(it<maxI){it++;var adj={};basisArcs.forEach(function(bid){var ba=arcById(bid);if(!ba)return;if(!adj[ba.from])adj[ba.from]=[];if(!adj[ba.to])adj[ba.to]=[];adj[ba.from].push({n:ba.to,key:bid,fwd:true});adj[ba.to].push({n:ba.from,key:bid,fwd:false})});var deltas=[];nonBasis.forEach(function(nbid){var nba=arcById(nbid);if(!nba)return;var cyc=findCyc(nba.from,nba.to,adj,nbid);if(!cyc)return;var dz=0;cyc.forEach(function(ce){var ca=arcById(ce.key);if(ce.dir==='+')dz+=ca.cost;else dz-=ca.cost});deltas.push({key:nbid,dz:dz,cycle:cyc})});var ent=null,minDz=0;deltas.forEach(function(d){if(d.dz<minDz){minDz=d.dz;ent=d}});if(!ent){var cg=deltas.map(function(d){return'dZ('+d.key+') = '+d.dz});cg.push('Semua dZ >= 0, OPTIMAL');cg.push('Z* = '+Z());iterStates.push({title:'OPTIMAL - Iterasi '+(it+1),desc:'Tidak ada reduced cost negatif',changes:cg,flows:Object.assign({},flows),basis:basisArcs.slice()});break}
var theta=Infinity,lk=null;ent.cycle.forEach(function(ce){if(ce.key===ent.key)return;if(ce.dir==='-'&&flows[ce.key]<theta){theta=flows[ce.key];lk=ce.key}});var ea=arcById(ent.key);if(ea.cap!==Infinity&&ea.cap<theta){theta=ea.cap;lk=ent.key}if(theta===Infinity)theta=0;
ent.cycle.forEach(function(ce){if(ce.dir==='+')flows[ce.key]+=theta;else flows[ce.key]-=theta});
if(lk&&lk!==ent.key){var li=basisArcs.indexOf(lk);if(li>=0)basisArcs.splice(li,1);basisArcs.push(ent.key);var ei=nonBasis.indexOf(ent.key);if(ei>=0)nonBasis.splice(ei,1);nonBasis.push(lk)}
var ec=[];deltas.forEach(function(d){ec.push('dZ('+d.key+') = '+d.dz)});ec.push('Entering: x_'+ent.key+' (dZ='+minDz+')');ec.push('theta = '+theta);if(lk)ec.push('Leaving: x_'+lk);var fS2=[];for(var k3 in flows)if(flows[k3]>0)fS2.push('x_'+k3+'='+flows[k3]);ec.push('Solusi: '+fS2.join(', '));ec.push('Z = '+Z());iterStates.push({title:'Iterasi '+(it+1)+' - Perbaikan',desc:'Entering: x_'+ent.key+', Leaving: x_'+(lk||'-'),changes:ec,flows:Object.assign({},flows),basis:basisArcs.slice()})}
return{flows:flows,z:Z()}}
function findCyc(from,to,adj,eid){var vis={},par={},q=[to];vis[to]=true;var found=false;while(q.length){var cur=q.shift();if(cur===from){found=true;break}(adj[cur]||[]).forEach(function(e){if(!vis[e.n]){vis[e.n]=true;par[e.n]={from:cur,key:e.key,fwd:e.fwd};q.push(e.n)}})}if(!found)return null;var cyc=[{key:eid,dir:'+'}],c2=from;while(c2!==to){var p=par[c2];cyc.push({key:p.key,dir:p.fwd?'-':'+'});c2=p.from}return cyc}
function findTree(nds,acs){var n=nds.length,conn={},ta=[],rem=acs.slice();conn[nds[0].id]=true;var s=0;while(ta.length<n-1&&s<n*n){s++;var added=false;for(var i=0;i<rem.length;i++){var a=rem[i],fI=!!conn[a.from],tI=!!conn[a.to];if((fI&&!tI)||(tI&&!fI)){conn[a.from]=true;conn[a.to]=true;ta.push(a.id);rem.splice(i,1);added=true;break}}if(!added){for(var j=0;j<nds.length;j++){if(!conn[nds[j].id]){for(var k=0;k<rem.length;k++){if(rem[k].from===nds[j].id||rem[k].to===nds[j].id){conn[rem[k].from]=true;conn[rem[k].to]=true;ta.push(rem[k].id);rem.splice(k,1);added=true;break}}if(added)break}}if(!added)break}}return ta.length>=n-1?ta:null}
function solveFlows(nds,acs,bids){var flows={};acs.forEach(function(a){flows[a.id]=0});var bArcs=bids.map(function(id){return acs.find(function(a){return a.id===id})});var tAdj={};nds.forEach(function(nd){tAdj[nd.id]=[]});bArcs.forEach(function(a){tAdj[a.from].push({arc:a,dir:'out'});tAdj[a.to].push({arc:a,dir:'in'})});var solved={},rem=nds.map(function(n){return n.id}),s=0;while(rem.length>1&&s<nds.length*nds.length){s++;var lf=false;for(var i=0;i<rem.length;i++){var nid=rem[i],unsol=[];tAdj[nid].forEach(function(e){if(!solved[e.arc.id])unsol.push(e)});if(unsol.length===1){var nd=nds.find(function(x){return x.id===nid}),e=unsol[0],kf=0;tAdj[nid].forEach(function(e2){if(solved[e2.arc.id]){if(e2.dir==='out')kf+=flows[e2.arc.id];else kf-=flows[e2.arc.id]}});var need=nd.bi-kf;if(e.dir==='out')flows[e.arc.id]=need;else flows[e.arc.id]=-need;solved[e.arc.id]=true;rem.splice(i,1);lf=true;break}}if(!lf)break}for(var fk in flows)if(flows[fk]<0)flows[fk]=0;return flows}
function buildSolRes(){if(!sol)return;document.getElementById('solBanner').innerHTML='<div class="wb"><h3>'+ico('trophy','lg')+' Solusi Optimal</h3><p>'+pickP('solOpt')+' <strong>'+sol.z+'</strong></p></div>';document.getElementById('solStats').innerHTML='<div class="stat-card hi"><div class="sv">'+sol.z+'</div><div class="sl">Total Biaya</div></div><div class="stat-card"><div class="sv">'+nodes.length+'</div><div class="sl">Nodes</div></div><div class="stat-card"><div class="sv">'+arcs.length+'</div><div class="sl">Arcs</div></div><div class="stat-card"><div class="sv">'+iterStates.length+'</div><div class="sl">Iterasi</div></div>';var h='<table class="rt"><tr><th>Jalur</th><th>Dari</th><th>Ke</th><th>Aliran</th><th>Biaya/unit</th><th>Total</th></tr>';arcs.forEach(function(a){var f=sol.flows[a.id]||0;h+='<tr><td>'+a.from+'->'+a.to+'</td><td>'+nodeName(a.from)+'</td><td>'+nodeName(a.to)+'</td><td style="font-weight:700;color:'+(f>0?'var(--green)':'var(--text3)')+'">'+f+'</td><td>'+a.cost+'</td><td>'+(f*a.cost)+'</td></tr>'});h+='<tr style="font-weight:700;background:var(--accent-bg)"><td colspan="5">TOTAL</td><td>'+sol.z+'</td></tr></table>';document.getElementById('solTable').innerHTML=h}
function iterGo(i){if(i<0)i=0;if(i>=iterStates.length)i=iterStates.length-1;curIter=i;document.getElementById('iterBadge').textContent=(curIter+1)+'/'+iterStates.length;document.getElementById('iterFirst').disabled=!curIter;document.getElementById('iterPrev').disabled=!curIter;document.getElementById('iterNext').disabled=curIter>=iterStates.length-1;document.getElementById('iterLast').disabled=curIter>=iterStates.length-1;var st=iterStates[curIter],el=document.getElementById('iterDetail');el.innerHTML='<div style="font-weight:700;margin-bottom:6px">'+st.title+'</div><div style="font-size:11px;color:var(--text3);margin-bottom:8px">'+st.desc+'</div>';if(st.flows){var fh='<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px">';for(var k in st.flows)if(st.flows[k]>0)fh+='<span class="badge badge-g">x<sub>'+k+'</sub>='+st.flows[k]+'</span>';fh+='</div>';el.innerHTML+=fh}var cl=document.getElementById('iterChanges');cl.innerHTML='';st.changes.forEach(function(c){cl.innerHTML+='<li>'+c+'</li>'});if(pos.length)drawGraph()}
function togglePlay(){if(playInt){clearInterval(playInt);playInt=null;document.getElementById('playBtn').textContent='Play'}else{document.getElementById('playBtn').textContent='Stop';playInt=setInterval(function(){if(curIter>=iterStates.length-1){clearInterval(playInt);playInt=null;document.getElementById('playBtn').textContent='Play';return}iterGo(curIter+1)},playSpd)}}

/* ===== CANVAS ===== */
function initCanvas(){cvEl=document.getElementById('cv');ctx=cvEl.getContext('2d');cvEl.addEventListener('mousedown',onMD);cvEl.addEventListener('mousemove',onMM);cvEl.addEventListener('mouseup',onMU);cvEl.addEventListener('mouseleave',onMU);cvEl.addEventListener('touchstart',onTD,{passive:false});cvEl.addEventListener('touchmove',onTM,{passive:false});cvEl.addEventListener('touchend',onMU)}
function cP(e){var r=cvEl.getBoundingClientRect();return{x:(e.clientX-r.left)/sc,y:(e.clientY-r.top)/sc}}
function onMD(e){var p=cP(e);for(var i=pos.length-1;i>=0;i--){var dx=p.x-pos[i].x,dy=p.y-pos[i].y;if(dx*dx+dy*dy<1200){di=i;dOff={x:dx,y:dy};cvEl.style.cursor='grabbing';return}}}
function onMM(e){if(di<0)return;var p=cP(e);pos[di]={x:p.x-dOff.x,y:p.y-dOff.y};drawGraph()}
function onMU(){di=-1;cvEl.style.cursor='grab'}
function onTD(e){e.preventDefault();var t=e.touches[0],r=cvEl.getBoundingClientRect(),p={x:(t.clientX-r.left)/sc,y:(t.clientY-r.top)/sc};for(var i=pos.length-1;i>=0;i--){var dx=p.x-pos[i].x,dy=p.y-pos[i].y;if(dx*dx+dy*dy<1200){di=i;dOff={x:dx,y:dy};return}}}
function onTM(e){if(di<0)return;e.preventDefault();var t=e.touches[0],r=cvEl.getBoundingClientRect(),p={x:(t.clientX-r.left)/sc,y:(t.clientY-r.top)/sc};pos[di]={x:p.x-dOff.x,y:p.y-dOff.y};drawGraph()}
function zoomIn(){sc=Math.min(sc*1.2,3);drawGraph()}function zoomOut(){sc=Math.max(sc/1.2,.3);drawGraph()}function zoomReset(){sc=1;drawGraph()}
function setLayout(t,btn){cLo=t;document.querySelectorAll('.layout-btns button').forEach(function(b){b.classList.remove('on')});if(btn)btn.classList.add('on');applyLayout();drawGraph()}
function applyLayout(){var W=800,H=580,pad=80,n=nodes.length;if(cLo==='circle'){var cx=W/2,cy=H/2,r=Math.min(W,H)*.34;for(var i=0;i<n;i++){var a=2*Math.PI*i/n-Math.PI/2;pos[i]={x:cx+r*Math.cos(a),y:cy+r*Math.sin(a)}}}else if(cLo==='lr'){var s2=[],t2=[],d2=[];nodes.forEach(function(nd,i){if(nd.type==='supply')s2.push(i);else if(nd.type==='demand')d2.push(i);else t2.push(i)});var cols=[s2,t2,d2].filter(function(c){return c.length>0});cols.forEach(function(col,ci){var x2=pad+ci*(W-2*pad)/(cols.length-1||1);col.forEach(function(ni,ri){pos[ni]={x:x2,y:col.length===1?H/2:pad+ri*(H-2*pad)/(col.length-1)}})})}else if(cLo==='grid'){var c2=Math.ceil(Math.sqrt(n));for(var i=0;i<n;i++){pos[i]={x:pad+(i%c2)*(W-2*pad)/(c2-1||1),y:pad+Math.floor(i/c2)*(H-2*pad)/(Math.ceil(n/c2)-1||1)}}}else if(cLo==='force'){for(var i=0;i<n;i++)pos[i]={x:pad+Math.random()*(W-2*pad),y:pad+Math.random()*(H-2*pad)}}else{var s3=[],t3=[],d3=[];nodes.forEach(function(nd,i){if(nd.type==='supply')s3.push(i);else if(nd.type==='demand')d3.push(i);else t3.push(i)});s3.forEach(function(ni,ri){pos[ni]={x:120,y:s3.length===1?H/2:pad+ri*(H-2*pad)/(s3.length-1)}});t3.forEach(function(ni,ri){pos[ni]={x:W/2,y:t3.length===1?H/2:pad+ri*(H-2*pad)/(t3.length-1)}});d3.forEach(function(ni,ri){pos[ni]={x:W-120,y:d3.length===1?H/2:pad+ri*(H-2*pad)/(d3.length-1)}})}}
function updateLegend(){document.getElementById('gLegend').style.display='flex';document.getElementById('gLegend').innerHTML='<span style="font-weight:700;font-size:9px;text-transform:uppercase;letter-spacing:1px">Legend:</span><span class="g-legend-item"><span class="g-legend-dot" style="background:var(--green)"></span> Supply</span><span class="g-legend-item"><span class="g-legend-dot" style="background:var(--amber)"></span> Transit</span><span class="g-legend-item"><span class="g-legend-dot" style="background:var(--red)"></span> Demand</span>'}
function drawGraph(){if(!cvEl||!pos.length)return;var dpr=window.devicePixelRatio||1,W=cvEl.parentElement.clientWidth,H=580;cvEl.style.width=W+'px';cvEl.style.height=H+'px';cvEl.width=W*dpr;cvEl.height=H*dpr;ctx.setTransform(dpr*sc,0,0,dpr*sc,0,0);var cs=getComputedStyle(document.documentElement);var cBg=cs.getPropertyValue('--canvas-bg').trim(),nF=cs.getPropertyValue('--node-fill').trim(),eC=cs.getPropertyValue('--edge-color').trim(),tC=cs.getPropertyValue('--text').trim(),t2c=cs.getPropertyValue('--text2').trim(),t3c=cs.getPropertyValue('--text3').trim(),gC=cs.getPropertyValue('--green').trim(),rC=cs.getPropertyValue('--red').trim(),aC=cs.getPropertyValue('--amber').trim(),bC=cs.getPropertyValue('--blue').trim();var gt=GRAPH_THEMES[gTheme]||GRAPH_THEMES.default;var thBg=gt.bg||cBg,thNF=gt.nodeFill||nF,thEA=gt.edgeActive||tC,thEI=gt.edgeInactive||eC,thGlow=gt.glow||bC,thLB=gt.labelBg||cBg,supC=gt.supply||gC,traC=gt.transit||aC,demC=gt.demand||rC;ctx.fillStyle=thBg;ctx.fillRect(0,0,W/sc,H/sc);if(gTheme==='blueprint'){ctx.strokeStyle='rgba(100,180,255,.06)';ctx.lineWidth=.5;for(var gx=0;gx<W/sc;gx+=30){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H/sc);ctx.stroke()}for(var gy=0;gy<H/sc;gy+=30){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W/sc,gy);ctx.stroke()}}
var nIdx={};nodes.forEach(function(nd,i){nIdx[nd.id]=i});var curFlows=iterStates[curIter]?iterStates[curIter].flows:null;var curBasis=iterStates[curIter]?iterStates[curIter].basis:null;var isD=gView==='detailed',isC=gView==='compact',NR=isC?22:NODE_R,labels=[];var pMap={};arcs.forEach(function(a){var pk=[a.from,a.to].sort().join('_');if(!pMap[pk])pMap[pk]=[];pMap[pk].push(a)});
arcs.forEach(function(arc){var fi=nIdx[arc.from],ti=nIdx[arc.to];if(fi===undefined||ti===undefined)return;var x1=pos[fi].x,y1=pos[fi].y,x2=pos[ti].x,y2=pos[ti].y,isBas=curBasis&&curBasis.indexOf(arc.id)>=0,flow=curFlows?curFlows[arc.id]||0:0,col=isBas?thEA:thEI,lw=isBas?(flow>0?2.8:1.8):.8,dx=x2-x1,dy=y2-y1,len=Math.sqrt(dx*dx+dy*dy)||1,ux=dx/len,uy=dy/len;var pk=[arc.from,arc.to].sort().join('_'),par=pMap[pk]&&pMap[pk].length>1,curve=0;if(par){var idx=pMap[pk].indexOf(arc);curve=(idx===0?35:-35);if(arc.from>arc.to)curve=-curve}if(isBas&&flow>0&&gt.nodeGlow){ctx.save();ctx.shadowColor=thGlow;ctx.shadowBlur=14}var lPt;if(curve){var mx2=(x1+x2)/2,my2=(y1+y2)/2,nx2=-dy/len,ny2=dx/len,cpx=mx2+nx2*curve,cpy=my2+ny2*curve;ctx.save();ctx.beginPath();ctx.moveTo(x1,y1);ctx.quadraticCurveTo(cpx,cpy,x2,y2);ctx.strokeStyle=col;ctx.lineWidth=lw;if(!isBas)ctx.setLineDash([5,4]);ctx.stroke();ctx.setLineDash([]);ctx.restore();var tv=1-NR/len,tanX=2*(1-tv)*(cpx-x1)+2*tv*(x2-cpx),tanY=2*(1-tv)*(cpy-y1)+2*tv*(y2-cpy),tl=Math.sqrt(tanX*tanX+tanY*tanY)||1;drawAH(ctx,x1*(1-tv)*(1-tv)+2*cpx*tv*(1-tv)+x2*tv*tv,y1*(1-tv)*(1-tv)+2*cpy*tv*(1-tv)+y2*tv*tv,tanX/tl,tanY/tl,isBas?10:7,col);lPt={x:cpx*.65+mx2*.35,y:cpy*.65+my2*.35}}else{ctx.save();ctx.beginPath();ctx.moveTo(x1+ux*NR,y1+uy*NR);ctx.lineTo(x2-ux*NR,y2-uy*NR);ctx.strokeStyle=col;ctx.lineWidth=lw;if(!isBas)ctx.setLineDash([5,4]);ctx.stroke();ctx.setLineDash([]);ctx.restore();drawAH(ctx,x2-ux*NR,y2-uy*NR,ux,uy,isBas?10:7,col);lPt={x:x1+dx*.45+(-uy)*(par?30:18),y:y1+dy*.45+ux*(par?30:18)}}if(isBas&&flow>0&&gt.nodeGlow)ctx.restore();if(lPt&&!isC){var fP=fixLbl(lPt,labels,50),txt='c='+arc.cost;if(curFlows&&flow>0)txt=flow+' | c='+arc.cost;if(isD)txt=arc.id+': '+(curFlows&&flow>0?flow+'u':'c='+arc.cost);ctx.font='600 8px JetBrains Mono,monospace';ctx.textAlign='center';ctx.textBaseline='middle';var tw=ctx.measureText(txt).width,bw=tw+8,bh=15;rR(ctx,fP.x-bw/2,fP.y-bh/2,bw,bh,3);ctx.fillStyle=thLB;ctx.fill();ctx.strokeStyle=isBas?col:thEI;ctx.lineWidth=.5;rR(ctx,fP.x-bw/2,fP.y-bh/2,bw,bh,3);ctx.stroke();ctx.fillStyle=isBas?thEA:t2c;ctx.fillText(txt,fP.x,fP.y);if(arc.cap!==Infinity){ctx.font='600 7px JetBrains Mono';ctx.fillStyle=traC;ctx.fillText('U<='+arc.cap,fP.x,fP.y+bh/2+9)}labels.push({x:fP.x,y:fP.y,w:bw,h:bh})}else if(isC){var mp={x:(x1+x2)/2,y:(y1+y2)/2};if(curve)mp=lPt;ctx.font='600 7px JetBrains Mono';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillStyle=isBas?thEA:t3c;ctx.fillText(arc.cost+'',mp.x,mp.y)}});
for(var i=0;i<nodes.length;i++){if(!pos[i])continue;var nd=nodes[i],x=pos[i].x,y=pos[i].y,nCol=nd.type==='supply'?supC:nd.type==='demand'?demC:traC;if(gt.nodeGlow){ctx.save();ctx.shadowColor=nCol;ctx.shadowBlur=18;ctx.beginPath();ctx.arc(x,y,NR,0,Math.PI*2);ctx.fillStyle=thNF;ctx.fill();ctx.restore()}ctx.beginPath();ctx.arc(x,y,NR,0,Math.PI*2);ctx.fillStyle=thNF;ctx.fill();ctx.strokeStyle=nCol;ctx.lineWidth=2.5;ctx.stroke();ctx.beginPath();ctx.arc(x,y,NR*.7,0,Math.PI*2);ctx.strokeStyle=nCol;ctx.lineWidth=.4;ctx.globalAlpha=.2;ctx.stroke();ctx.globalAlpha=1;ctx.beginPath();ctx.arc(x+NR*.6,y-NR*.6,3,0,Math.PI*2);ctx.fillStyle=nCol;ctx.fill();ctx.font='700 '+(isC?13:16)+'px JetBrains Mono,monospace';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillStyle=gt.bg?'#fff':tC;ctx.fillText(nd.id,x,y);var vStr='['+(nd.bi>0?'+':'')+nd.bi+']';ctx.font='600 '+(isC?8:9)+'px JetBrains Mono';var vW=ctx.measureText(vStr).width;rR(ctx,x-vW/2-5,y-NR-20,vW+10,15,4);ctx.fillStyle=nCol;ctx.globalAlpha=.15;ctx.fill();ctx.globalAlpha=1;rR(ctx,x-vW/2-5,y-NR-20,vW+10,15,4);ctx.strokeStyle=nCol;ctx.lineWidth=.6;ctx.stroke();ctx.fillStyle=nCol;ctx.textAlign='center';ctx.fillText(vStr,x,y-NR-12);if(!isC){var nm=nd.name;if(nm.length>16)nm=nm.substring(0,14)+'...';ctx.font='500 8px DM Sans,sans-serif';var nmW=ctx.measureText(nm).width;rR(ctx,x-nmW/2-5,y+NR+5,nmW+10,14,3);ctx.fillStyle=thBg;ctx.fill();ctx.strokeStyle=thEI;ctx.lineWidth=.3;rR(ctx,x-nmW/2-5,y+NR+5,nmW+10,14,3);ctx.stroke();ctx.fillStyle=t2c;ctx.textAlign='center';ctx.fillText(nm,x,y+NR+12);if(isD){ctx.font='600 7px JetBrains Mono';var tl=nd.type.toUpperCase(),tlW=ctx.measureText(tl).width;rR(ctx,x-tlW/2-4,y+NR+21,tlW+8,12,3);ctx.fillStyle=nCol;ctx.globalAlpha=.1;ctx.fill();ctx.globalAlpha=1;ctx.fillStyle=nCol;ctx.fillText(tl,x,y+NR+27)}}}ctx.font='500 9px JetBrains Mono';ctx.fillStyle=gt.bg?'rgba(255,255,255,.04)':'rgba(0,0,0,.04)';ctx.textAlign='right';ctx.fillText('RADSTRIX',W/sc-10,H/sc-8)}
function fixLbl(pt,ex,md){var adj={x:pt.x,y:pt.y};for(var a=0;a<12;a++){var ok=true;for(var i=0;i<ex.length;i++){var dx=adj.x-ex[i].x,dy=adj.y-ex[i].y;if(Math.sqrt(dx*dx+dy*dy)<md){ok=false;break}}for(var i=0;i<pos.length;i++){var dx=adj.x-pos[i].x,dy=adj.y-pos[i].y;if(Math.sqrt(dx*dx+dy*dy)<NODE_R+20){ok=false;break}}if(ok)break;var ang=Math.PI*2*a/12;adj={x:pt.x+Math.cos(ang)*22,y:pt.y+Math.sin(ang)*18}}return adj}
function rR(c,x,y,w,h,r){c.beginPath();c.moveTo(x+r,y);c.lineTo(x+w-r,y);c.quadraticCurveTo(x+w,y,x+w,y+r);c.lineTo(x+w,y+h-r);c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);c.lineTo(x+r,y+h);c.quadraticCurveTo(x,y+h,x,y+h-r);c.lineTo(x,y+r);c.quadraticCurveTo(x,y,x+r,y);c.closePath()}
function drawAH(c,tx,ty,ux,uy,sz,col){var bx=tx-ux*sz,by=ty-uy*sz,px=-uy,py=ux;c.beginPath();c.moveTo(tx,ty);c.lineTo(bx+px*sz*.4,by+py*sz*.4);c.lineTo(bx-px*sz*.4,by-py*sz*.4);c.closePath();c.fillStyle=col;c.fill()}
function resetAll(){sol=null;curIter=0;iterStates=[];if(playInt)clearInterval(playInt);playInt=null;nodes=[];arcs=[];pos=[];['sec2','sec3','sec4','sec5'].forEach(function(id){document.getElementById(id).style.display='none'});document.getElementById('aiResult').classList.remove('show');document.getElementById('aiSoalInput').value='';rebuildNodeGrid();toast('Reset','info')}
document.addEventListener('keydown',function(e){if(e.target.tagName==='INPUT'||e.target.tagName==='SELECT'||e.target.tagName==='TEXTAREA')return;if(e.key==='ArrowRight')iterGo(curIter+1);else if(e.key==='ArrowLeft')iterGo(curIter-1);else if(e.key==='Home')iterGo(0);else if(e.key==='End')iterGo(iterStates.length-1);else if(e.key===' '){e.preventDefault();togglePlay()}else if(e.key==='d'||e.key==='D')toggleDark()});
</script>
</body>
</html>
